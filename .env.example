# ======================================================================
# Special Day Platform — konfiguracija
# Kopiraj u .env i popuni. Pravi .env se NIKAD ne commituje.
# ======================================================================

# --- Baza (MySQL 8) ---
# Lokalni dev: mysql://USER:PASSWORD@localhost:3306/specialday
# Produkcija (HestiaCP): baza kreirana kroz Hestia panel
DATABASE_URL="mysql://root:CHANGE_ME@localhost:3306/specialday"

# --- Backend API ---
API_PORT=4000
# Tačan origin frontenda (CORS + cookies). Prod: https://tvojadomena.ba
FRONTEND_ORIGIN="http://localhost:3000"
# Minimum 32 znaka — generiši sa: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="CHANGE_ME_MIN_32_CHARS"
# Folder za slike (relativno od backend/ ili apsolutna putanja)
UPLOADS_DIR="../uploads"
# 'production' na VPS-u — uključuje Secure cookies i skriva error stackove
NODE_ENV="development"

# --- Seed (koristi se SAMO pri prisma db seed) ---
SEED_SUPERADMIN_EMAIL="admin@example.com"
SEED_SUPERADMIN_PASSWORD="CHANGE_ME_STRONG"
SEED_DEMO_CLIENT_EMAIL="demo@example.com"
SEED_DEMO_CLIENT_PASSWORD="CHANGE_ME_STRONG"

# --- Frontend (Next.js) ---
# Javna adresa API-ja koju browser vidi. Prod: https://tvojadomena.ba (nginx proxy /api)
NEXT_PUBLIC_API_URL="http://localhost:4000"
