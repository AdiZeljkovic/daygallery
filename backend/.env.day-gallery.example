# ================================================================
# backend/.env  —  PRODUKCIJA: day-gallery.com
# Kopiraj u backend/.env na serveru i popuni lozinke.
# ================================================================

# ISTA baza kao stari vhost — svi podaci i legacyId (stari QR kodovi) su već tu.
# NE praviti novu bazu, inače stari QR kodovi neće raditi!
# connection_limit/pool_timeout — deterministički Prisma pool (usklađen s MySQL max_connections)
DATABASE_URL="mysql://adizeljkovic_daygallery:TVOJA_DB_LOZINKA@localhost:3306/adizeljkovic_daygallery?connection_limit=10&pool_timeout=10"

# Interni port API-ja — MORA biti 4712 (nginx template proxira ovamo).
# Stari vhost koristi 4711, zato su različiti da mogu raditi paralelno.
API_PORT=4712

NODE_ENV="production"

# CORS: apex + www (zarezom). Bez www bi www.day-gallery.com pucao.
FRONTEND_ORIGIN="https://day-gallery.com,https://www.day-gallery.com"

# Generiši novi: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="CHANGE_ME_MIN_32_HEKS"

# Slike — apsolutna putanja u NOVOM vhostu (kopiraćeš ih iz starog, vidi DEPLOY-DAY-GALLERY.md)
UPLOADS_DIR="/home/day-gallery/web/day-gallery.com/uploads"

# Error tracking (opcionalno) — bez DSN-a je neaktivan
SENTRY_DSN=""

# Seed — NE koristi na produkciji (baza je već popunjena)
# SEED_SUPERADMIN_EMAIL=""
# SEED_SUPERADMIN_PASSWORD=""
