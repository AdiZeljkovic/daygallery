# ======================================================================
# PRODUKCIJA — backend/.env na VPS-u (Hetzner + HestiaCP)
# Kopiraj u backend/.env i popuni. NIKAD ne commituj pravi .env.
# ======================================================================

# --- Baza (kreiraj kroz HestiaCP → Databases) ---
# Format: mysql://KORISNIK:LOZINKA@localhost:3306/IME_BAZE
DATABASE_URL="mysql://adizeljkovic_dg:CHANGE_ME@localhost:3306/adizeljkovic_dg"

# --- Backend API ---
API_PORT=4711
NODE_ENV="production"

# Javna adresa (frontend i API su na istoj domeni → cookies first-party)
FRONTEND_ORIGIN="https://daygallery.adizeljkovic.com"

# Generiši: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="CHANGE_ME_MIN_32_HEKS"

# Folder za slike — apsolutna putanja na serveru
UPLOADS_DIR="/home/adizeljkovic/web/daygallery.adizeljkovic.com/uploads"

# Error tracking (opcionalno) — bez DSN-a je potpuno neaktivan.
# Napravi besplatan projekat na sentry.io i zalijepi DSN ovdje.
SENTRY_DSN=""

# Seed (koristi se samo ako pokreneš prisma db seed — na prod obično NE)
SEED_SUPERADMIN_EMAIL="admin@daygallery.adizeljkovic.com"
SEED_SUPERADMIN_PASSWORD="CHANGE_ME_JAKA"
SEED_DEMO_CLIENT_EMAIL="demo@daygallery.adizeljkovic.com"
SEED_DEMO_CLIENT_PASSWORD="CHANGE_ME_JAKA"
